<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BadgerRide" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:colorPrimary">@color/bg</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:textColorPrimary">@color/text</item>
        <item name="android:fontFamily">@font/lora</item>
        <item name="android:colorControlActivated">@color/accent</item>
        <item name="android:colorControlNormal">@color/neutral_600</item>
        <item name="android:textColorHighlight">#4DB68235</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!-- Uppercase kicker labels, per the design's letterspaced caps -->
    <style name="MetricLabel">
        <item name="android:textSize">10sp</item>
        <item name="android:letterSpacing">0.14</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/accent_700</item>
    </style>
    <style name="MiniLabel">
        <item name="android:textSize">8.5sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/text_muted</item>
    </style>
    <style name="SectionLabel">
        <item name="android:textSize">10.5sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/accent_700</item>
    </style>
    <style name="PanelLabel">
        <item name="android:textSize">9.5sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/text_muted</item>
    </style>

    <!-- .btn-secondary: hairline border, heading font -->
    <style name="BtnStep">
        <item name="android:background">@drawable/btn_secondary</item>
        <item name="android:fontFamily">@font/cormorant_semibold</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:gravity">center</item>
        <item name="android:minWidth">52dp</item>
        <item name="android:fontFeatureSettings">\'tnum\'</item>
    </style>

    <!-- .seg-opt -->
    <style name="SegOpt">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/seg_text</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:background">@drawable/seg_option</item>
    </style>

    <style name="FieldLabel">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_label</item>
        <item name="android:layout_marginBottom">5dp</item>
    </style>
    <style name="Input">
        <item name="android:background">@drawable/input_bg</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:minHeight">44dp</item>
    </style>
</resources>
